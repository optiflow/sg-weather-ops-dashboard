{
  "name": "sg-weather-ops-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w frontend && tsc -p backend/tsconfig.json",
    "docs:build": "npm run build -w docs",
    "start": "node scripts/start.mjs",
    "doctor": "node scripts/doctor.mjs",
    "reset": "node scripts/reset.mjs",
    "docs": "npm run dev -w docs",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:e2e": "playwright test",
    "test:watch": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx backend/src/migrate.ts"
  },
  "workspaces": [
    "frontend",
    "backend",
    "docs"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "portless": "^0.12.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
